// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  RESIDENT
  ADMIN
}

enum IssueCategory {
  ROADS
  LIGHTING
  WATER
  PARKS
  WASTE
  OTHER
}

enum IssueStatus {
  NEW
  UNDER_REVIEW
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectCategory {
  ROADS
  LIGHTING
  PARKS
  EDUCATION
  WASTE
  OTHER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  REPORT_CREATED
  STATUS_CHANGED
  ISSUE_REJECTED
  ISSUE_COMPLETED
}

model User {
  id                Int              @id @default(autoincrement())
  email             String           @unique
  passwordHash      String
  fullName          String
  role              UserRole         @default(RESIDENT)
  preferredLanguage String           @default("en")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  issues            Issue[]          @relation("IssueAuthor")
  votes             Vote[]
  statusChanges     IssueStatusHistory[] @relation("StatusChangedBy")
  notifications     Notification[]
}

model Issue {
  id              Int                @id @default(autoincrement())
  title           String
  description     String
  category        IssueCategory
  status          IssueStatus        @default(NEW)
  priority        Priority           @default(MEDIUM)
  address         String
  latitude        Float
  longitude       Float
  isVisibleOnMap  Boolean            @default(true)
  rejectionReason String?            // filled when REJECTED
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  authorId Int
  author   User               @relation("IssueAuthor", fields: [authorId], references: [id])

  projectId Int?
  project   Project?          @relation(fields: [projectId], references: [id])

  statusHistory IssueStatusHistory[]
  votes         Vote[]
  notifications Notification[]
}

model IssueStatusHistory {
  id        Int          @id @default(autoincrement())
  status    IssueStatus
  changedAt DateTime     @default(now())
  note      String?

  issueId Int
  issue   Issue         @relation(fields: [issueId], references: [id])

  changedById Int?
  changedBy   User?     @relation("StatusChangedBy", fields: [changedById], references: [id])
}

model Project {
  id            Int               @id @default(autoincrement())
  name          String
  description   String
  category      ProjectCategory
  district      String
  status        ProjectStatus     @default(PLANNED)
  plannedBudget Float             // k EUR
  spentBudget   Float             @default(0)
  period        String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  issues      Issue[]
  milestones  ProjectMilestone[]
}

model ProjectMilestone {
  id        Int            @id @default(autoincrement())
  label     String
  status    ProjectStatus
  date      DateTime
  note      String?

  projectId Int
  project   Project        @relation(fields: [projectId], references: [id])
}

model Vote {
  userId  Int
  issueId Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  issue Issue @relation(fields: [issueId], references: [id])

  @@id([userId, issueId]) // один голос на заявку от пользователя
}

model Notification {
  id               Int              @id @default(autoincrement())
  type             NotificationType
  email            String
  subject          String
  body             String
  sentSuccessfully Boolean          @default(true)
  createdAt        DateTime         @default(now())

  userId  Int
  user    User   @relation(fields: [userId], references: [id])

  issueId Int?
  issue   Issue? @relation(fields: [issueId], references: [id])
}